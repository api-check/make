{
  "name": "Search Municipality",
  "description": "Search for municipalities (gemeenten) by name. Primarily relevant for Belgium.",
  "type": "action",
  "parameters": [
    {"name": "country", "type": "select", "label": "Country", "options": {"be": "Belgium", "nl": "Netherlands"}, "required": true, "default": "be"},
    {"name": "name", "type": "text", "label": "Municipality Name", "required": true, "placeholder": "Antwerpen"},
    {"name": "limit", "type": "number", "label": "Limit", "required": false, "default": 10}
  ],
  "api": {"method": "GET", "url": "/search/v1/municipality/{{parameters.country}}", "query": {"name": "{{parameters.name}}", "limit": "{{parameters.limit}}"}},
  "response": {"output": "{{response}}", "iterate": true},
  "sample": {"id": 222, "name": "Antwerpen"}
}
